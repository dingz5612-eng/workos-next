    },
    "/api/workspaces/{workspaceId}/cards/{cardId}/confirm": {
      "post": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "cardId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Token", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "X-Request-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConfirmCardRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Business facts committed; projection may be projected, pending, or failed independently",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConfirmCardResponse" }
              }
            }
          },
          "400": { "description": "Malformed confirm request" },
          "401": { "description": "Actor session missing or expired" },
          "403": { "description": "AI, role, or slice capability forbids confirmation" },
          "409": { "description": "Idempotency conflict" },
          "422": { "description": "Business policy violation" },
          "404": { "description": "Card not found" }
        }
      }
    },
    "/api/workspaces/{workspaceId}/events": {
      "get": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Audit events for one workspace" }
        }
      }
    },
    "/api/audit-events": {
      "get": {
        "responses": {
          "200": { "description": "Audit event journal" }
        }
      }
    },
    "/api/outbox": {
      "get": {
        "responses": {
          "200": { "description": "Outbox messages" }
        }
      }
    },
    "/api/projections/process-outbox": {
      "post": {
        "responses": {
          "200": { "description": "Processes pending projection outbox messages" }
        }
      }
    },
    "/api/behavior-events": {
      "get": {
        "responses": {
          "200": { "description": "Behavior event stream" }
        }
      },
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BehaviorEventRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Behavior event accepted" }
        }
      }
    },
    "/api/observability/runtime": {
      "get": {
        "responses": {
          "200": {
            "description": "Runtime observation counters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RuntimeObservation" }
              }
            }
          }
        }
      }
    }
  },
