{
  "openapi": "3.1.0",
  "info": {
    "title": "WorkOSNext Runtime API",
    "version": "0.13.0"
  },
  "paths": {
    "/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Runtime health"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Actor session issued" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/sessions/{token}/revoke": {
      "post": {
        "parameters": [
          { "name": "token", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Runtime session revoked" }
        }
      }
    },
    "/api/device-sessions": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RuntimeDeviceSessionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Device session registered" }
        }
      }
    },
    "/api/device-sessions/{deviceId}/revoke": {
      "post": {
        "parameters": [
          { "name": "deviceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Device revoked" },
          "404": { "description": "Device session not found" }
        }
      }
    },
    "/api/workspaces": {
      "get": {
        "responses": {
          "200": {
            "description": "Projection envelope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projection-contract.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/workspaces/{workspaceId}": {
      "get": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Single workspace projection" },
          "404": { "description": "Workspace not found" }
        }
      }
    },
    "/api/bootstrap": {
      "get": {
        "responses": {
          "200": { "description": "Development bootstrap payload" }
        }
      }
    },
    "/api/work-queue": {
      "get": {
        "responses": {
          "200": { "description": "Workbench queue lens" }
        }
      }
    },
    "/api/operations/cases": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOperationCaseRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Existing operation case projection resolved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationCase" }
              }
            }
          },
          "422": { "description": "No persisted operation case or workspace projection could be resolved" }
        }
      }
    },
    "/api/operations/cases/{caseId}": {
      "get": {
        "parameters": [
          { "name": "caseId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Existing operation case projection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationCase" }
              }
            }
          },
          "404": { "description": "Operation case not found" }
        }
      }
    },
    "/api/operations/work-items": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWorkItemRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Existing operation work item projection resolved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkItem" }
              }
            }
          },
          "422": { "description": "No persisted process intent or workspace card could be resolved" }
        }
      },
      "get": {
        "parameters": [
          { "name": "tenantId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "caseId", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Operation work items from process-manager intents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorkItem" }
                }
              }
            }
          }
        }
      }
    },
    "/api/operations/work-items/{workItemId}": {
      "get": {
        "parameters": [
          { "name": "workItemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Operation work item projection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkItem" }
              }
            }
          },
          "404": { "description": "Operation work item not found" }
        }
      }
    },
    "/api/operations/work-items/{workItemId}/prepare": {
      "post": {
        "parameters": [
          { "name": "workItemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PrepareWorkItemRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation work item field contract prepared",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PrepareWorkItemResult" }
              }
            }
          },
          "404": { "description": "Operation work item or backing card not found" }
        }
      }
    },
    "/api/operations/work-items/{workItemId}/confirm": {
      "post": {
        "parameters": [
          { "name": "workItemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Token", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "X-Request-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConfirmWorkItemRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation confirmation committed through the runtime",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConfirmWorkItemResult" }
              }
            }
          },
          "400": { "description": "Malformed confirm request" },
          "401": { "description": "Actor session missing or expired" },
          "403": { "description": "Actor role or slice capability forbids confirmation" },
          "422": { "description": "Business policy violation" },
          "404": { "description": "Operation work item or backing card not found" }
        }
      }
    },
    "/api/operations/trace/submissions/{submissionId}": {
      "get": {
        "parameters": [
          { "name": "submissionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Fact trace for a command submission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FactTrace" }
              }
            }
          },
          "404": { "description": "Submission trace not found" }
        }
      }
    },
    "/api/operations/trace/work-items/{workItemId}": {
      "get": {
        "parameters": [
          { "name": "workItemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Fact traces for a work item",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/FactTrace" }
                }
              }
            }
          }
        }
      }
    },
    "/api/operations/trace/cases/{caseId}": {
      "get": {
        "parameters": [
          { "name": "caseId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Fact traces for an operation case",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/FactTrace" }
                }
              }
            }
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "parameters": [
          { "name": "q", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Search lens results" }
        }
      }
    },
    "/api/lenses/work-queue": {
      "get": {
        "responses": {
          "200": { "description": "Workbench queue lens" }
        }
      }
    },
    "/api/lenses/home-surface": {
      "get": {
        "responses": {
          "200": { "description": "Runtime home surface lens" }
        }
      }
    },
    "/api/lenses/search": {
      "get": {
        "parameters": [
          { "name": "q", "in": "query", "required": false, "schema": { "type": "string" } }
