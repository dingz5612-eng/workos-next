{
  "openapi": "3.1.0",
  "info": {
    "title": "WorkOSNext Runtime API",
    "version": "0.13.0"
  },
  "paths": {
    "/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Runtime health"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Actor session issued" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/sessions/{token}/revoke": {
      "post": {
        "parameters": [
          { "name": "token", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Runtime session revoked" }
        }
      }
    },
    "/api/device-sessions": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RuntimeDeviceSessionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Device session registered" }
        }
      }
    },
    "/api/device-sessions/{deviceId}/revoke": {
      "post": {
        "parameters": [
          { "name": "deviceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Device revoked" },
          "404": { "description": "Device session not found" }
        }
      }
    },
    "/api/workspaces": {
      "get": {
        "responses": {
          "200": {
            "description": "Projection envelope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projection-contract.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/workspaces/{workspaceId}": {
      "get": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Single workspace projection" },
          "404": { "description": "Workspace not found" }
        }
      }
    },
    "/api/bootstrap": {
      "get": {
        "responses": {
          "200": { "description": "Development bootstrap payload" }
        }
      }
    },
    "/api/work-queue": {
      "get": {
        "responses": {
          "200": { "description": "Workbench queue lens" }
        }
      }
    },
    "/api/search": {
      "get": {
        "parameters": [
          { "name": "q", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Search lens results" }
        }
      }
    },
    "/api/lenses/work-queue": {
      "get": {
        "responses": {
          "200": { "description": "Workbench queue lens" }
        }
      }
    },
    "/api/lenses/home-surface": {
      "get": {
        "responses": {
          "200": { "description": "Runtime home surface lens" }
        }
      }
    },
    "/api/lenses/search": {
      "get": {
        "parameters": [
          { "name": "q", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Search lens results" }
        }
      }
    },
    "/api/lenses/learning-catalog": {
      "get": {
        "responses": {
          "200": { "description": "Runtime learning catalog lens" }
        }
      }
    },
    "/api/lenses/accommodation/{lensId}": {
      "get": {
        "parameters": [
          {
            "name": "lensId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["bed-inventory", "room-readiness", "rate-plan", "blocked-bed", "room-revenue-potential", "today-operations", "lead-funnel", "active-stay", "deposit-liability", "payment-risk", "stay-balance", "checkout-queue", "service-task-queue", "expense-analytics", "period-performance", "risk-command"]
            }
          }
        ],
        "responses": {
          "200": { "description": "Accommodation aggregate lens results" }
        }
      }
    },
    "/api/control-plane/releases": {
      "get": {
        "responses": {
          "200": { "description": "Release Control Center release summaries" }
        }
      }
    },
    "/api/control-plane/releases/{releaseId}": {
      "get": {
        "parameters": [
          { "name": "releaseId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Release Control Center release detail" },
          "404": { "description": "Release manifest not found" }
        }
      }
    },
    "/api/control-plane/gate-results/{gateResultId}": {
      "get": {
        "parameters": [
          { "name": "gateResultId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "GateResult detail" },
          "404": { "description": "GateResult not found" }
        }
      }
    },
    "/api/control-plane/shadow-compare-reports/{id}": {
      "get": {
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Shadow compare report detail" },
          "404": { "description": "Shadow compare report not found" }
        }
      }
    },
    "/api/control-plane/invariant-checks": {
      "get": {
        "parameters": [
          { "name": "releaseId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Runtime invariant checks for a release" }
        }
      }
    },
    "/api/control-plane/rollback-instructions/{id}": {
      "get": {
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Rollback or compensation instruction detail" },
          "404": { "description": "Rollback instruction not found" }
        }
      }
    },
    "/api/evidence": {
      "get": {
        "parameters": [
          { "name": "evidenceId", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Evidence object runtime records" }
        }
      }
    },
    "/api/evidence/drafts": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvidenceDraftRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Evidence draft created or restored" }
        }
      }
    },
    "/api/evidence/{evidenceId}/attachments": {
      "post": {
        "parameters": [
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvidenceAttachmentRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Evidence attachment metadata added" }
        }
      }
    },
    "/api/evidence/{evidenceId}/verify": {
      "post": {
        "parameters": [
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvidenceDecisionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Evidence verified" }
        }
      }
    },
    "/api/evidence/{evidenceId}/reject": {
      "post": {
        "parameters": [
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvidenceDecisionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Evidence rejected" }
        }
      }
    },
    "/api/evidence/{evidenceId}/signed-url": {
      "get": {
        "parameters": [
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "actorId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "deviceId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "ttlSeconds", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Audited expiring signed URL for evidence attachment",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EvidenceSignedUrlResponse" }
              }
            }
          },
          "403": { "description": "Evidence access forbidden" }
        }
      }
    },
    "/api/workspaces/{workspaceId}/cards/{cardId}/prepare": {
      "post": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "cardId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PrepareCardRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Prepared card" },
          "404": { "description": "Card not found" }
        }
      }
    },
    "/api/pc-governance/exports/{exportType}": {
      "post": {
        "parameters": [
          { "name": "exportType", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GovernanceExportRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Audited export accepted" },
          "403": { "description": "Export blocked by capability, reason, or trusted-device policy" }
        }
      }
    },
    "/api/workspaces/{workspaceId}/cards/{cardId}/confirm": {
      "post": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "cardId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-WorkOS-Actor-Token", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "X-Request-Id", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConfirmCardRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Business facts committed; projection may be projected, pending, or failed independently",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConfirmCardResponse" }
              }
            }
          },
          "400": { "description": "Malformed confirm request" },
          "401": { "description": "Actor session missing or expired" },
          "403": { "description": "AI, role, or slice capability forbids confirmation" },
          "409": { "description": "Idempotency conflict" },
          "422": { "description": "Business policy violation" },
          "404": { "description": "Card not found" }
        }
      }
    },
    "/api/workspaces/{workspaceId}/events": {
      "get": {
        "parameters": [
          { "name": "workspaceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Audit events for one workspace" }
        }
      }
    },
    "/api/audit-events": {
      "get": {
        "responses": {
          "200": { "description": "Audit event journal" }
        }
      }
    },
    "/api/outbox": {
      "get": {
        "responses": {
          "200": { "description": "Outbox messages" }
        }
      }
    },
    "/api/projections/process-outbox": {
      "post": {
        "responses": {
          "200": { "description": "Processes pending projection outbox messages" }
        }
      }
    },
    "/api/behavior-events": {
      "get": {
        "responses": {
          "200": { "description": "Behavior event stream" }
        }
      },
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BehaviorEventRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Behavior event accepted" }
        }
      }
    },
    "/api/observability/runtime": {
      "get": {
        "responses": {
          "200": {
            "description": "Runtime observation counters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RuntimeObservation" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "RuntimeDeviceSessionRequest": {
        "type": "object",
        "required": ["tenantId", "actorId", "deviceId", "deviceTrustStatus", "userAgentHash"],
        "properties": {
          "tenantId": { "type": "string" },
          "actorId": { "type": "string" },
          "deviceId": { "type": "string" },
          "deviceTrustStatus": { "type": "string", "enum": ["unknown", "trusted", "untrusted", "revoked"] },
          "userAgentHash": { "type": "string" }
        }
      },
      "ConfirmCardRequest": {
        "type": "object",
        "required": ["language", "idempotencyKey", "submissionId", "cardInstanceId", "fieldValues", "evidenceIds"],
        "properties": {
          "language": { "type": "string" },
          "idempotencyKey": { "type": "string" },
          "submissionId": { "type": "string" },
          "cardInstanceId": { "type": "string" },
          "aggregateRef": { "type": ["string", "null"] },
          "fieldValues": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "evidenceIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requestId": { "type": ["string", "null"] },
          "deviceId": { "type": ["string", "null"] }
        }
      },
      "ConfirmCardResponse": {
        "type": "object",
        "required": ["confirmed", "commitStatus", "projectionStatus", "caseId", "workItemId", "submissionId", "resultEventIds", "userMessage", "clientInstruction"],
        "properties": {
          "confirmed": { "type": "boolean", "const": true },
          "commitStatus": { "type": "string", "enum": ["committed"] },
          "projectionStatus": { "type": "string", "enum": ["projected", "pending", "failed"] },
          "caseId": { "type": "string" },
          "workItemId": { "type": "string" },
          "submissionId": { "type": "string" },
          "resultEventIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "userMessage": { "type": "string" },
          "clientInstruction": {
            "type": "object",
            "required": ["disableRetry", "refreshProjection", "observeOutbox"],
            "properties": {
              "disableRetry": { "type": "boolean" },
              "refreshProjection": { "type": "boolean" },
              "observeOutbox": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "events": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "projection": {
            "anyOf": [
              { "type": "object", "additionalProperties": true },
              { "type": "null" }
            ]
          }
        }
      },
      "PrepareCardRequest": {
        "type": "object",
        "properties": {
          "submissionId": { "type": ["string", "null"] },
          "cardInstanceId": { "type": ["string", "null"] },
          "aggregateRef": { "type": ["string", "null"] }
        }
      },
      "EvidenceDraftRequest": {
        "type": "object",
        "required": ["workspaceId", "cardId", "cardInstanceId", "submissionId", "requirementId"],
        "properties": {
          "workspaceId": { "type": "string" },
          "cardId": { "type": "string" },
          "cardInstanceId": { "type": "string" },
          "submissionId": { "type": "string" },
          "requirementId": { "type": "string" },
          "evidenceId": { "type": ["string", "null"] }
        }
      },
      "EvidenceAttachmentRequest": {
        "type": "object",
        "required": ["fileName", "contentType", "contentSha256", "sizeBytes"],
        "properties": {
          "fileName": { "type": "string" },
          "contentType": { "type": "string" },
          "contentSha256": { "type": "string" },
          "sizeBytes": { "type": "integer" }
        }
      },
      "EvidenceDecisionRequest": {
        "type": "object",
        "required": ["actorId"],
        "properties": {
          "actorId": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "EvidenceSignedUrlResponse": {
        "type": "object",
        "required": ["evidenceId", "attachmentId", "url", "expiresAtUtc", "auditEventId"],
        "properties": {
          "evidenceId": { "type": "string" },
          "attachmentId": { "type": "string" },
          "url": { "type": "string" },
          "expiresAtUtc": { "type": "string", "format": "date-time" },
          "auditEventId": { "type": "string" }
        }
      },
      "GovernanceExportRequest": {
        "type": "object",
        "required": ["exportType", "actorId", "actorRole", "deviceId", "deviceTrustStatus", "surface", "reason"],
        "properties": {
          "exportType": { "type": "string" },
          "actorId": { "type": "string" },
          "actorRole": { "type": "string" },
          "actorCapabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deviceId": { "type": "string" },
          "deviceTrustStatus": { "type": "string", "enum": ["unknown", "trusted", "untrusted", "revoked"] },
          "surface": { "type": "string" },
          "reason": { "type": "string" },
          "nowUtc": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "RuntimeObservation": {
        "type": "object",
        "required": ["service", "version", "persistence", "workspaceCount", "cardCount", "auditEventCount", "outboxCount", "pendingOutboxCount", "deadLetterOutboxCount", "behaviorEventCount", "projectionLagSeconds", "failedConfirmReasonDistribution", "surfaceCoverageMissingCount", "ledgerInvariantViolationCount", "schemaVersion", "activeArchitectureExceptionCount", "activeArchitectureExceptions", "productionMetrics"],
        "properties": {
          "service": { "type": "string" },
          "version": { "type": "string" },
          "persistence": { "type": "string" },
          "workspaceCount": { "type": "integer" },
          "cardCount": { "type": "integer" },
          "auditEventCount": { "type": "integer" },
          "outboxCount": { "type": "integer" },
          "pendingOutboxCount": { "type": "integer" },
          "deadLetterOutboxCount": { "type": "integer" },
          "behaviorEventCount": { "type": "integer" },
          "lastAuditEventAtUtc": { "type": ["string", "null"], "format": "date-time" },
          "projectionLagSeconds": { "type": "integer" },
          "failedConfirmReasonDistribution": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          },
          "surfaceCoverageMissingCount": { "type": "integer" },
          "ledgerInvariantViolationCount": { "type": "integer" },
          "schemaVersion": { "type": "string" },
          "activeArchitectureExceptionCount": { "type": "integer" },
          "activeArchitectureExceptions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "productionMetrics": { "$ref": "#/components/schemas/ProductionObservabilityMetrics" }
        }
      },
      "ProductionObservabilityMetrics": {
        "type": "object",
        "required": ["runtime", "outbox", "projection", "mobile", "money", "deposit", "checkout", "controlPlane", "generatedAtUtc"],
        "properties": {
          "runtime": { "$ref": "#/components/schemas/RuntimeProductionMetrics" },
          "outbox": { "$ref": "#/components/schemas/OutboxProductionMetrics" },
          "projection": { "$ref": "#/components/schemas/ProjectionProductionMetrics" },
          "mobile": { "$ref": "#/components/schemas/MobileProductionMetrics" },
          "money": { "$ref": "#/components/schemas/MoneyProductionMetrics" },
          "deposit": { "$ref": "#/components/schemas/DepositProductionMetrics" },
          "checkout": { "$ref": "#/components/schemas/CheckoutProductionMetrics" },
          "controlPlane": { "$ref": "#/components/schemas/ControlPlaneProductionMetrics" },
          "generatedAtUtc": { "type": "string", "format": "date-time" }
        }
      },
      "RuntimeProductionMetrics": {
        "type": "object",
        "required": ["confirmLatencyP95Ms", "confirmLatencySampleCount", "confirmFailureCount", "idempotencyConflictCount", "forbiddenCount403", "conflictCount409", "validationCount422", "handlerFailureCount"],
        "properties": {
          "confirmLatencyP95Ms": { "type": "integer" },
          "confirmLatencySampleCount": { "type": "integer" },
          "confirmFailureCount": { "type": "integer" },
          "idempotencyConflictCount": { "type": "integer" },
          "forbiddenCount403": { "type": "integer" },
          "conflictCount409": { "type": "integer" },
          "validationCount422": { "type": "integer" },
          "handlerFailureCount": { "type": "integer" }
        }
      },
      "OutboxProductionMetrics": {
        "type": "object",
        "required": ["outboxLagSeconds", "deadLetterCount", "replayCount"],
        "properties": {
          "outboxLagSeconds": { "type": "integer" },
          "deadLetterCount": { "type": "integer" },
          "replayCount": { "type": "integer" }
        }
      },
      "ProjectionProductionMetrics": {
        "type": "object",
        "required": ["projectionLagSeconds", "rebuildCount", "staleLensCount"],
        "properties": {
          "projectionLagSeconds": { "type": "integer" },
          "rebuildCount": { "type": "integer" },
          "staleLensCount": { "type": "integer" }
        }
      },
      "MobileProductionMetrics": {
        "type": "object",
        "required": ["workItemBundleP95Ms", "workItemBundleSampleCount", "uploadFailureCount", "submitRetryCount", "draftRecoveryCount"],
        "properties": {
          "workItemBundleP95Ms": { "type": "integer" },
          "workItemBundleSampleCount": { "type": "integer" },
          "uploadFailureCount": { "type": "integer" },
          "submitRetryCount": { "type": "integer" },
          "draftRecoveryCount": { "type": "integer" }
        }
      },
      "MoneyProductionMetrics": {
        "type": "object",
        "required": ["paymentConfirmWithoutEvidenceViolations", "allocationOverAvailableViolations", "stayBalanceMismatchCount"],
        "properties": {
          "paymentConfirmWithoutEvidenceViolations": { "type": "integer" },
          "allocationOverAvailableViolations": { "type": "integer" },
          "stayBalanceMismatchCount": { "type": "integer" }
        }
      },
      "DepositProductionMetrics": {
        "type": "object",
        "required": ["availableRefundNegativeCount", "refundFailedDoubleCount", "heldAmountNegativeCount"],
        "properties": {
          "availableRefundNegativeCount": { "type": "integer" },
          "refundFailedDoubleCount": { "type": "integer" },
          "heldAmountNegativeCount": { "type": "integer" }
        }
      },
      "CheckoutProductionMetrics": {
        "type": "object",
