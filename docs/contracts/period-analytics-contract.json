{
  "version": "0.14.0-accommodation-workos",
  "sliceId": "Accommodation.PeriodAnalytics",
  "snapshotPolicy": {
    "snapshotType": "frozen-period-snapshot",
    "freezeEvent": "Accommodation.PeriodMetricsReviewed",
    "lateAdjustmentPolicy": "append-adjustment-event",
    "lateAdjustmentEvents": [
      "Accommodation.PeriodFinanceReviewed",
      "Accommodation.PeriodOperationsDiagnosed",
      "Accommodation.PeriodActionPlanCommitted",
      "Accommodation.PeriodActionPlanWorkItemCreated",
      "Accommodation.PeriodActionPlanCompleted"
    ],
    "rule": "After a period snapshot is frozen, late source events do not mutate the frozen values. They append adjustment events that are visible in the next review or an explicit reopened review."
  },
  "actionPlanWorkItems": {
    "commitEvent": "Accommodation.PeriodActionPlanCommitted",
    "workItemCreatedEvent": "Accommodation.PeriodActionPlanWorkItemCreated",
    "completeEvent": "Accommodation.PeriodActionPlanCompleted",
    "workItemType": "periodActionPlanExecution",
    "requiredFields": ["ownerRole", "dueAtUtc", "priority"],
    "rules": [
      "PeriodActionPlanCommitted creates executable WorkItem intent and does not mark the action plan completed.",
      "PeriodActionPlanCompleted is a later event and must reference the action plan WorkItem.",
      "Action plans are structured governance work and must not be stored as free-text notes only."
    ]
  },
  "periodClose": {
    "closeEvent": "Accommodation.PeriodReviewClosed",
    "requiredConditions": [
      "scopeConfirmed",
      "metricsReviewed",
      "financeReviewed",
      "operationsDiagnosed",
      "actionPlanCommittedOrSkipped",
      "noBlockingInvariantViolation",
      "businessSignoffCompleted"
    ],
    "rules": [
      "PeriodReviewClosed freezes final metric, finance, and operation snapshot source high-watermarks.",
      "PeriodReviewClosed records source_projection_versions, source_ledger_versions, and source_lens_versions on the frozen snapshots.",
      "After PeriodReviewClosed, snapshot rows are append-only and must not be edited for late changes."
    ]
  },
  "lateAdjustments": {
    "table": "period_late_adjustments",
    "requiredFields": ["reason", "createdBy", "body.before", "body.after"],
    "rules": [
      "LateAdjustment can only append after PeriodReviewClosed.",
      "LateAdjustment must not overwrite the original frozen snapshot.",
      "LateAdjustment must be visible from Period detail and RiskCommandLens."
    ]
  },
  "zeroDenominator": {
    "numericResult": "0",
    "status": "not_applicable",
    "rule": "If a denominator is zero, the displayed ratio is 0 and the formula status is not_applicable instead of throwing or hiding the metric."
  },
  "formulas": [
    {
      "id": "averageOccupancyRate",
      "label": "平均入住率",
      "expression": "bedNightSold / availableBedNight",
      "numerator": "bedNightSold",
      "denominator": "availableBedNight",
      "zeroDenominator": "not_applicable"
    },
    {
      "id": "leadToReservationRate",
      "label": "线索转预订率",
      "expression": "reservationCount / newLeadCount",
      "numerator": "reservationCount",
      "denominator": "newLeadCount",
      "zeroDenominator": "not_applicable"
    },
    {
      "id": "reservationToCheckInRate",
      "label": "预订转入住率",
      "expression": "checkInCount / reservationCount",
      "numerator": "checkInCount",
      "denominator": "reservationCount",
      "zeroDenominator": "not_applicable"
    },
    {
      "id": "periodNetCashFlow",
      "label": "周期净现金流",
      "expression": "rentRevenue + otherRevenue - approvedExpenseAmount",
      "excludes": ["depositReceivedAmount", "depositRefundedAmount"],
      "zeroDenominator": "not_applicable"
    },
    {
      "id": "depositLiabilityEnd",
      "label": "期末押金负债",
      "expression": "depositReceivedAmount - depositRefundedAmount - depositDeductedAmount - depositAppliedToBalanceAmount",
      "zeroDenominator": "not_applicable"
    }
  ]
}
