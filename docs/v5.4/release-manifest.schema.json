{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkOSNext V5.4 Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "mr_id",
    "release_name",
    "status",
    "owners",
    "commit_sha",
    "migration_version",
    "definition_version",
    "api_schema_hash",
    "ci_run_id",
    "gate_result_id",
    "rollback_instruction_id",
    "feature_flag_ids",
    "slice_cutover_state_ids",
    "shadow_compare_report_ids",
    "invariant_check_ids",
    "acceptance_scenarios",
    "go_criteria",
    "no_go_criteria",
    "known_risks",
    "created_at_utc",
    "updated_at_utc",
    "released_at_utc",
    "locked_at_utc"
  ],
  "properties": {
    "release_id": { "type": "string", "minLength": 1 },
    "mr_id": { "type": "string", "minLength": 1 },
    "release_name": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "built",
        "shadow",
        "pilot",
        "active",
        "locked",
        "paused",
        "rollback",
        "compensating",
        "rejected"
      ]
    },
    "owners": { "type": "array", "items": { "type": "string" } },
    "commit_sha": { "type": "string" },
    "migration_version": { "type": "string" },
    "definition_version": { "type": "string" },
    "api_schema_hash": { "type": "string" },
    "ci_run_id": { "type": ["string", "null"] },
    "gate_result_id": { "type": "string" },
    "rollback_instruction_id": { "type": "string" },
    "feature_flag_ids": { "type": "array", "items": { "type": "string" } },
    "slice_cutover_state_ids": { "type": "array", "items": { "type": "string" } },
    "shadow_compare_report_ids": { "type": "array", "items": { "type": "string" } },
    "invariant_check_ids": { "type": "array", "items": { "type": "string" } },
    "acceptance_scenarios": { "type": "array", "items": { "type": "string" } },
    "go_criteria": { "type": "array", "items": { "type": "string" } },
    "no_go_criteria": { "type": "array", "items": { "type": "string" } },
    "known_risks": { "type": "array", "items": { "type": "string" } },
    "created_at_utc": { "type": "string" },
    "updated_at_utc": { "type": "string" },
    "released_at_utc": { "type": ["string", "null"] },
    "locked_at_utc": { "type": ["string", "null"] }
  }
}
